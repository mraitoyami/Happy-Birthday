<script>
/* ─── Navigation ─── */
let cur = 1, qrDone = false;
function go(n){
  if(n===cur) return;
  document.getElementById('p'+cur).classList.remove('active');
  document.getElementById('p'+n).classList.add('active');
  document.querySelectorAll('#dots .dot').forEach((d,i)=>d.classList.toggle('on',i===n-1));
  cur = n;
  if(n===1||n===3) confetti(28);
  if(n===5&&!qrDone){ makeQR(); qrDone=true; }
}
document.addEventListener('keydown',e=>{
  if(e.key==='ArrowRight'&&cur<5) go(cur+1);
  if(e.key==='ArrowLeft'&&cur>1)  go(cur-1);
});

/* ─── Happy Birthday — Web Audio ─── */
let audioCtx=null, musicPlaying=false, musicLoop=null;
const NOTES={G4:392,A4:440,B4:494,C5:523,D5:587,E5:659,F5:698,G5:784,R:0};
const MELODY=[
  ['G4',.75],['G4',.25],['A4',1],['G4',1],['C5',1],['B4',2],['R',.5],
  ['G4',.75],['G4',.25],['A4',1],['G4',1],['D5',1],['C5',2],['R',.5],
  ['G4',.75],['G4',.25],['G5',1],['E5',1],['C5',1],['B4',1],['A4',2],['R',.5],
  ['F5',.75],['F5',.25],['E5',1],['C5',1],['D5',1],['C5',2.5],['R',1]
];
const BEAT=60/108;

function playMelody(ctx,t,vol=0.27){
  let totalDur=0;
  for(const [note,dur] of MELODY){
    const d=dur*BEAT;
    if(note!=='R'){
      const o=ctx.createOscillator(),g=ctx.createGain();
      o.connect(g);g.connect(ctx.destination);
      o.type='sine';o.frequency.value=NOTES[note];
      g.gain.setValueAtTime(0,t);
      g.gain.linearRampToValueAtTime(vol,t+0.04);
      g.gain.setValueAtTime(vol,t+d*.7);
      g.gain.linearRampToValueAtTime(0,t+d-0.04);
      o.start(t);o.stop(t+d);
      const o2=ctx.createOscillator(),g2=ctx.createGain();
      o2.connect(g2);g2.connect(ctx.destination);
      o2.type='triangle';o2.frequency.value=NOTES[note]*2;
      g2.gain.setValueAtTime(0,t);
      g2.gain.linearRampToValueAtTime(vol*.18,t+0.04);
      g2.gain.linearRampToValueAtTime(0,t+d-0.04);
      o2.start(t);o2.stop(t+d);
    }
    t+=d; totalDur+=d;
  }
  return totalDur;
}
function startMusic(){
  if(!audioCtx) audioCtx=new(window.AudioContext||window.webkitAudioContext)();
  if(audioCtx.state==='suspended') audioCtx.resume();
  musicPlaying=true;
  document.getElementById('musicBtn').textContent='🔇';
  let next=audioCtx.currentTime+0.1;
  function sched(){
    const dur=playMelody(audioCtx,next);
    next+=dur;
    musicLoop=setTimeout(sched,(next-audioCtx.currentTime-.5)*1000);
  }
  sched();
}
function stopMusic(){
  musicPlaying=false;clearTimeout(musicLoop);
  if(audioCtx){audioCtx.close();audioCtx=null;}
  document.getElementById('musicBtn').textContent='🎵';
}
function toggleMusic(){ musicPlaying?stopMusic():startMusic(); }

/* ─── Canvas backgrounds ─── */
function drawHeart(ctx,x,y,s){
  ctx.save();ctx.translate(x,y);
  ctx.beginPath();
  ctx.moveTo(s/2,s/4);
  ctx.quadraticCurveTo(s/2,0,s*3/4,0);
  ctx.quadraticCurveTo(s,0,s,s/4);
  ctx.quadraticCurveTo(s,s/2,s/2,s*3/4);
  ctx.quadraticCurveTo(0,s/2,0,s/4);
  ctx.quadraticCurveTo(0,0,s/4,0);
  ctx.quadraticCurveTo(s/2,0,s/2,s/4);
  ctx.fill();ctx.restore();
}
function drawHeartsCanvas(canvas){
  canvas.width=window.innerWidth;canvas.height=window.innerHeight;
  const ctx=canvas.getContext('2d');
  ctx.fillStyle='#ffeef4';ctx.fillRect(0,0,canvas.width,canvas.height);
  const sizes=[10,14,18,22,26,12,16,20];
  const pinks=['#ff6b9d','#ff9eb5','#ff7aaa','#ff5488','#ffb3cc'];
  for(let x=0;x<canvas.width+40;x+=36){
    for(let y=0;y<canvas.height+40;y+=36){
      const s=sizes[Math.floor(Math.random()*sizes.length)];
      const ox=x+(Math.random()-.5)*18,oy=y+(Math.random()-.5)*18;
      ctx.globalAlpha=.45+Math.random()*.45;
      ctx.fillStyle=pinks[Math.floor(Math.random()*pinks.length)];
      drawHeart(ctx,ox-s/2,oy-s/2,s);
    }
  }
  ctx.globalAlpha=1;
}
function drawStarsCanvas(canvas){
  canvas.width=window.innerWidth;canvas.height=window.innerHeight;
  const ctx=canvas.getContext('2d');
  const g=ctx.createRadialGradient(canvas.width*.3,canvas.height*.3,0,canvas.width*.5,canvas.height*.5,canvas.width*.8);
  g.addColorStop(0,'#0d0d2a');g.addColorStop(1,'#000005');
  ctx.fillStyle=g;ctx.fillRect(0,0,canvas.width,canvas.height);
  for(let i=0;i<280;i++){
    const x=Math.random()*canvas.width,y=Math.random()*canvas.height;
    const r=Math.random()*2.2+.3,b=.3+Math.random()*.7;
    ctx.globalAlpha=b;
    ctx.fillStyle=`hsl(${200+Math.random()*60},${Math.random()>.8?30:0}%,95%)`;
    ctx.beginPath();ctx.arc(x,y,r,0,Math.PI*2);ctx.fill();
    if(r>1.6){
      ctx.globalAlpha=b*.4;ctx.strokeStyle='white';ctx.lineWidth=.8;
      ctx.beginPath();ctx.moveTo(x-r*4,y);ctx.lineTo(x+r*4,y);
      ctx.moveTo(x,y-r*4);ctx.lineTo(x,y+r*4);ctx.stroke();
    }
  }
  ctx.globalAlpha=1;
}

/* ─── Gift open / close ─── */
const gifts=[
  {type:'bouquet'},
  {type:'normal',emoji:'⭐',
   title:'Аз жаргалын одны хүслэл ⭐',
   text:'Алтантуяа, тэнгэрийн хамгийн гэрэлтэй одыг танд зориулав. Өнөөдөр нэг хүслэлээ дотроо хийгтүн — биелэх болтугай! Таны зам гэрэлтэй, ирээдүй дэлгэр байх болтугай. ✨🌟💫',
   bgImg:'hearts.jpg',bgFn:'hearts',lightCard:false},
  {type:'normal',emoji:'💝',
   title:'Мөнхийн буян ерөөл 💝',
   text:'Алтантуяа, урт удаан нас, эрүүл энх бие, дулаан гэр, аз жаргалтай амьдрал. Таны хайр халамж, сайхан зан маш олон хүнд жишээ болж байдаг. Үргэлж аз жаргалтай, баяр баясгалантай байж! 💖💗💕',
   bgImg:'stars.jpg',bgFn:'stars',lightCard:true}
];

function openGift(i){
  const box=document.getElementById('gb'+i);
  box.classList.add('pop');setTimeout(()=>box.classList.remove('pop'),600);
  confetti(24);

  const g=gifts[i];
  const canvas=document.getElementById('revealCanvas');
  const bgImg=document.getElementById('revealBgImg');
  const g0=document.getElementById('gift0content');
  const g12=document.getElementById('gift12content');
  const rcard=document.getElementById('rcard');

  // Reset card style
  rcard.style.background='rgba(255,255,255,.96)';
  document.getElementById('rTitle').style.color='#e63f7a';
  document.getElementById('rText').style.color='#888';

  if(g.type==='bouquet'){
    bgImg.style.display='none';
    canvas.style.display='none';
    document.getElementById('reveal').style.background='linear-gradient(145deg,#fff0f5,#ffe0ee)';
    g0.style.display='block'; g12.style.display='none';
  } else {
    document.getElementById('reveal').style.background='';
    g0.style.display='none'; g12.style.display='block';
    document.getElementById('rEmoji').textContent=g.emoji;
    document.getElementById('rTitle').textContent=g.title;
    document.getElementById('rText').textContent=g.text;

    if(g.lightCard){
      rcard.style.background='rgba(15,15,40,.82)';
      document.getElementById('rTitle').style.color='#ffb3cc';
      document.getElementById('rText').style.color='#ccc';
    }

    // Try real photo first, fall back to canvas
    bgImg.style.display='none';
    canvas.style.display='block';
    const testImg=new Image();
    testImg.onload=()=>{
      bgImg.src=g.bgImg;bgImg.style.display='block';
      canvas.style.display='none';
    };
    testImg.onerror=()=>{
      canvas.style.display='block';bgImg.style.display='none';
      if(g.bgFn==='hearts') drawHeartsCanvas(canvas);
      else drawStarsCanvas(canvas);
    };
    testImg.src=g.bgImg;
  }

  document.getElementById('reveal').classList.add('show');
}
function closeGift(){ document.getElementById('reveal').classList.remove('show'); }

/* ─── QR code ─── */
function makeQR(){
  new QRCode(document.getElementById('qrcode'),{
    text:'https://www.youtube.com/watch?v=1hbndwvpVa4',
    width:175,height:175,
    colorDark:'#e63f7a',colorLight:'#fff5f8',
    correctLevel:QRCode.CorrectLevel.H
  });
}

/* ─── Confetti ─── */
function confetti(n){
  const cols=['#ff6b9d','#ffb3cc','#ff3366','#ffd6e8','#e63f7a','#fffbe8','#ffcc44','#b2e0f0'];
  for(let i=0;i<n;i++){
    const el=document.createElement('div');el.className='cf';
    const sz=6+Math.random()*9;
    el.style.cssText=`left:${Math.random()*100}%;top:${-20+Math.random()*30}px;
      width:${sz}px;height:${sz}px;
      background:${cols[Math.floor(Math.random()*cols.length)]};
      border-radius:${Math.random()>.5?'50%':'2px'};
      animation-duration:${1.2+Math.random()*2.2}s;
      animation-delay:${Math.random()*.5}s;`;
    document.body.appendChild(el);setTimeout(()=>el.remove(),4000);
  }
}

/* ─── Floating hearts ─── */
(function(){
  const c=document.getElementById('hearts');
  const h=['❤️','💕','💖','💗','💓','💝','🌸','✨','🌷','💫'];
  for(let i=0;i<22;i++){
    const el=document.createElement('div');el.className='fh';
    el.textContent=h[Math.floor(Math.random()*h.length)];
    const dur=9+Math.random()*14;
    el.style.cssText=`left:${Math.random()*100}%;font-size:${10+Math.random()*18}px;
      animation-duration:${dur}s;animation-delay:${-Math.random()*dur}s;`;
    c.appendChild(el);
  }
})();
