<html lang="mn">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Алтантуяа — Төрсөн өдрийн мэнд! 🎂</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;600;700;800;900&family=Caveat:wght@400;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box}
html,body{width:100%;height:100%;overflow:hidden;
  font-family:'Noto Sans',sans-serif;background:#fff0f5}

/* ── Floating hearts ── */
#hearts{position:fixed;inset:0;pointer-events:none;z-index:0;overflow:hidden}
.fh{position:absolute;animation:riseHeart linear infinite;opacity:0}
@keyframes riseHeart{
  0%{transform:translateY(110vh) scale(.6) rotate(0deg);opacity:0}
  8%{opacity:.4}92%{opacity:.4}
  100%{transform:translateY(-120px) scale(1.1) rotate(20deg);opacity:0}}

/* ── Music button ── */
#musicBtn{
  position:fixed;top:14px;right:14px;z-index:80;
  background:rgba(255,255,255,.88);border:2px solid #ffaac4;
  border-radius:50%;width:46px;height:46px;
  font-size:21px;cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 4px 14px rgba(230,63,122,.22);
  backdrop-filter:blur(6px);transition:all .2s}
#musicBtn:hover{transform:scale(1.1);background:#ffe0ec}

/* ── Pages ── */
.page{
  position:absolute;inset:0;display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  opacity:0;pointer-events:none;
  transition:opacity .65s cubic-bezier(.4,0,.2,1);
  z-index:1;padding:20px 16px}
.page.active{opacity:1;pointer-events:all}

/* ── Nav dots ── */
#dots{position:fixed;bottom:16px;left:50%;transform:translateX(-50%);
  display:flex;gap:9px;z-index:60}
.dot{width:9px;height:9px;border-radius:50%;background:#ffb3cc;
  cursor:pointer;transition:background .3s,transform .3s;border:none}
.dot.on{background:#e63f7a;transform:scale(1.4)}

/* ── Shared ── */
.pg-title{
  font-size:clamp(1.55rem,3.8vw,2.1rem);font-weight:900;
  color:#e63f7a;margin-bottom:5px;text-align:center}
.pg-sub{color:#ff9eb5;font-size:.98rem;font-style:italic;margin-bottom:22px}

.btn{
  background:linear-gradient(135deg,#ff6b9d,#e63f7a);
  color:#fff;border:none;padding:14px 38px;
  border-radius:50px;font-size:1.08rem;font-weight:800;
  cursor:pointer;font-family:'Noto Sans',sans-serif;
  box-shadow:0 6px 22px rgba(230,63,122,.45);
  transition:transform .2s,box-shadow .2s}
.btn:hover{transform:translateY(-3px) scale(1.05);
  box-shadow:0 12px 28px rgba(230,63,122,.5)}
.btn:active{transform:scale(.97)}

@keyframes hpulse{0%,100%{transform:scale(1)}50%{transform:scale(1.18)}}
@keyframes cakeBob{0%,100%{transform:translateY(0) rotate(-4deg)}
  50%{transform:translateY(-18px) rotate(4deg)}}
@keyframes float3{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}

/* ════════════ PAGE 1 ════════════ */
#p1{background:linear-gradient(145deg,#fff0f5,#ffdde9,#ffc8d8)}
.p1-name{
  font-size:clamp(1.3rem,4vw,1.9rem);font-weight:900;
  color:#ff4d88;letter-spacing:.5px;
  text-shadow:0 2px 8px rgba(255,77,136,.2);margin-bottom:4px}
.p1-hearts{font-size:26px;margin-bottom:14px;
  animation:hpulse 2s ease-in-out infinite}
.p1-title{
  font-size:clamp(1.7rem,4.5vw,2.7rem);font-weight:900;
  background:linear-gradient(135deg,#e63f7a,#ff6baa);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  text-align:center;line-height:1.15;margin-bottom:6px}
.p1-sub{color:#ff7aaa;font-size:1.05rem;font-weight:700;margin-bottom:30px}
.p1-cake{font-size:82px;animation:cakeBob 2s ease-in-out infinite;
  margin-bottom:12px;filter:drop-shadow(0 8px 18px rgba(230,63,122,.28))}

/* ════════════ PAGE 2 — PRESENTS ════════════ */
#p2{background:linear-gradient(145deg,#fff5f8,#ffe4ef)}
.gifts-row{display:flex;gap:22px;align-items:flex-end;
  justify-content:center;margin-bottom:14px}
.gw{display:flex;flex-direction:column;align-items:center;cursor:pointer}
.gb{position:relative;width:108px;height:98px;transition:transform .25s}
.gb.big{width:128px;height:116px;margin-bottom:14px}
.gb:hover{transform:scale(1.08) translateY(-6px)}
.gb.pop{animation:gPop .55s cubic-bezier(.34,1.56,.64,1) forwards}
@keyframes gPop{0%{transform:scale(1)}35%{transform:scale(1.25) rotate(12deg)}
  65%{transform:scale(.92) rotate(-6deg)}100%{transform:scale(1) rotate(0)}}
.g-body{position:absolute;bottom:0;width:100%;height:75%;
  background:linear-gradient(145deg,#b2e0f0,#96cfe0);
  border-radius:8px;box-shadow:0 8px 22px rgba(100,185,215,.35);overflow:hidden}
.g-body::after{content:'';position:absolute;left:50%;transform:translateX(-50%);
  width:18px;height:100%;background:linear-gradient(180deg,#ffaac4,#ff6b9d)}
.g-lid{position:absolute;top:0;left:-5px;width:calc(100% + 10px);height:26%;
  background:linear-gradient(145deg,#c4eaf8,#aad8ec);
  border-radius:7px;box-shadow:0 3px 10px rgba(100,185,215,.3)}
.g-lid::after{content:'';position:absolute;left:50%;transform:translateX(-50%);
  width:18px;height:100%;background:linear-gradient(180deg,#ffcce0,#ff6b9d);border-radius:3px}
.g-bow{position:absolute;top:-17px;left:50%;transform:translateX(-50%);
  font-size:30px;z-index:2;line-height:1}
.g-label{margin-top:7px;font-size:.8rem;font-weight:700;color:#ff7aaa}

/* ── Gift Reveal Modal ── */
#reveal{position:fixed;inset:0;z-index:200;
  display:none;align-items:center;justify-content:center;overflow:hidden}
#reveal.show{display:flex}
#revealCanvas{position:absolute;inset:0;width:100%;height:100%}
#revealBgImg{position:absolute;inset:0;width:100%;height:100%;
  object-fit:cover;display:none}

.rcard{
  background:rgba(255,255,255,.96);border-radius:26px;
  padding:30px 28px;max-width:380px;width:90%;text-align:center;
  box-shadow:0 24px 60px rgba(0,0,0,.25);
  position:relative;z-index:2;
  animation:popIn .42s cubic-bezier(.34,1.56,.64,1)}
@keyframes popIn{from{transform:scale(.45) rotate(-8deg);opacity:0}
  to{transform:scale(1) rotate(0);opacity:1}}

/* Lily bouquet */
.flower-row{display:flex;justify-content:center;gap:3px;line-height:1}
.flower-row.r1{font-size:44px;margin-bottom:-8px}
.flower-row.r2{font-size:38px;margin-bottom:-6px}
.flower-row.r3{font-size:30px}
.bouquet-bow{font-size:34px;margin-top:3px}
.bouquet-stem{width:54px;height:26px;border-bottom:4px solid #5a8a3a;
  border-radius:0 0 50% 50%;margin-top:-3px;margin-bottom:10px}

/* Photo display in gift 1 */
#lilyImg{
  width:200px;height:200px;object-fit:cover;
  border-radius:20px;border:3px solid #ffcce0;
  box-shadow:0 8px 24px rgba(230,63,122,.25);
  margin-bottom:10px;display:none}

#rEmoji{font-size:60px;display:block;margin-bottom:8px;
  animation:spinY 1s ease}
@keyframes spinY{from{transform:rotateY(0)}to{transform:rotateY(360deg)}}
#rTitle{font-size:1.4rem;font-weight:900;color:#e63f7a;margin-bottom:8px}
#rText{color:#888;line-height:1.65;font-size:.93rem;margin-bottom:16px}
.sparkle-row{font-size:20px;margin-bottom:14px;animation:hpulse 2s ease-in-out infinite}
.close-btn{
  background:linear-gradient(135deg,#ff6b9d,#e63f7a);
  color:#fff;border:none;padding:11px 30px;border-radius:30px;
  cursor:pointer;font-family:'Noto Sans',sans-serif;
  font-size:1rem;font-weight:700}

/* ════════════ PAGE 3 — CAKE ════════════ */
#p3{background:linear-gradient(145deg,#fff8fc,#ffe8f4,#ffd8ee)}
.cake-img-wrap{
  margin:4px 0 10px;
  animation:float3 3s ease-in-out infinite;
  filter:drop-shadow(0 8px 20px rgba(230,63,122,.25))}
.cake-photo{
  width:min(200px,44vw);border-radius:50%;
  border:4px solid #ffc2d8;display:none}
.cake-svg{width:min(200px,44vw);height:auto}
.blessings-grid{display:grid;grid-template-columns:1fr 1fr;
  gap:10px;max-width:480px;width:100%;margin-bottom:12px}
.bl{
  background:#fff;border-radius:16px;padding:10px 13px;
  font-size:.85rem;font-weight:700;color:#e63f7a;
  box-shadow:0 4px 16px rgba(230,63,122,.18);
  border:2px solid #ffd6e8;text-align:center;line-height:1.45}

/* ════════════ PAGE 4 — LETTER ════════════ */
#p4{background:linear-gradient(145deg,#fff5f8,#ffe0ec)}
.letter-wrap{
  position:relative;
  background:repeating-linear-gradient(transparent,transparent 27px,#e4cfa8 27px,#e4cfa8 28px),
             linear-gradient(180deg,#fefcf0,#fef9e4);
  border-radius:14px;padding:26px 30px 30px;
  max-width:560px;width:calc(100% - 20px);
  box-shadow:0 12px 40px rgba(0,0,0,.14);
  max-height:54vh;overflow-y:auto}
.letter-wrap::-webkit-scrollbar{width:5px}
.letter-wrap::-webkit-scrollbar-thumb{background:#ffb3cc;border-radius:4px}
.lt{font-family:'Caveat',cursive;font-size:1.1rem;color:#7a5030;line-height:1.95}
.lsig{font-family:'Caveat',cursive;font-size:1.3rem;font-weight:700;
  color:#e63f7a;text-align:right;margin-top:12px}
.l-deco{position:absolute;bottom:-16px;left:10px;font-size:40px;pointer-events:none}
.l-flowers{position:absolute;top:-10px;right:10px;font-size:17px;pointer-events:none;opacity:.7}

/* ════════════ PAGE 5 — SONG ════════════ */
#p5{background:linear-gradient(145deg,#fff0f5,#ffe0ec)}
.qr-frame{
  background:#fff;border-radius:20px;padding:14px 14px 10px;
  box-shadow:0 10px 34px rgba(230,63,122,.22);
  border:3px solid #ffaac4;position:relative;display:inline-block;margin:6px 0}
.qr-corner{position:absolute;font-size:16px}
.qr-corner.tl{top:-9px;left:-9px}.qr-corner.tr{top:-9px;right:-9px}
.qr-corner.bl{bottom:-9px;left:-9px}.qr-corner.br{bottom:-9px;right:-9px}
.yt-btn{
  display:flex;align-items:center;gap:10px;
  background:linear-gradient(135deg,#ff1a1a,#cc0000);
  color:#fff;border:none;padding:14px 28px;border-radius:50px;
  font-size:1rem;font-weight:800;cursor:pointer;
  font-family:'Noto Sans',sans-serif;
  box-shadow:0 6px 22px rgba(200,0,0,.4);
  transition:transform .2s,box-shadow .2s;
  text-decoration:none;margin-top:8px}
.yt-btn:hover{transform:translateY(-3px) scale(1.05);
  box-shadow:0 12px 28px rgba(200,0,0,.5)}
.notes-row{font-size:22px;margin:8px 0;animation:hpulse 2s ease-in-out infinite}

/* ── Confetti ── */
.cf{position:fixed;pointer-events:none;z-index:300;
  border-radius:2px;animation:cfFall linear forwards}
@keyframes cfFall{
  0%{transform:translateY(-60px) rotate(0deg);opacity:1}
  100%{transform:translateY(110vh) rotate(800deg);opacity:0}}
</style>
</head>
<body>

<div id="hearts"></div>
<button id="musicBtn" onclick="toggleMusic()" title="Хөгжим тоглуулах">🎵</button>

<!-- ════════════════════════════
     PAGE 1 — LANDING
════════════════════════════ -->
<div class="page active" id="p1">
